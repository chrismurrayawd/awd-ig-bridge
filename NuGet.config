<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    The machine-level NuGet config has an empty <packageSources> (nuget.org cleared),
    so restore finds no feed. Re-establish the official feed scoped to this repo.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
